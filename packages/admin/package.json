{
    "name": "@padloc/admin",
    "version": "4.4.0",
    "author": "Martin Kleinschrodt <martin@maklesoft.com>",
    "license": "GPL-3.0",
    "private": true,
    "files": [
        "src",
        "tsconfig.json"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/padloc/padloc.git",
        "directory": "packages/pwa"
    },
    "engines": {
        "node": "24.x"
    },
    "dependencies": {
        "@padloc/app": "workspace:*",
        "@padloc/core": "workspace:*",
        "@padloc/locale": "workspace:*",
        "@types/diff": "5.0.2",
        "diff": "5.1.0",
        "lit": "2.3.1"
    },
    "devDependencies": {
        "http-server": "14.1.1",
        "sharp": "0.29.3",
        "ts-node": "10.9.2",
        "typescript": "7.0.2",
        "vite": "5.4.19",
        "vite-plugin-pwa": "0.21.2",
        "workbox-build": "7.3.0",
        "workbox-window": "7.3.0"
    },
    "description": "Padloc Admin Portal",
    "scripts": {
        "build": "vite build",
        "dev": "vite --host 0.0.0.0 --port ${PL_ADMIN_PORT:-9090}",
        "start": "http-server ${PL_ADMIN_DIR:-dist} -s -p ${PL_ADMIN_PORT:-9090} --proxy ${PL_ADMIN_URL:-http://0.0.0.0:${PL_ADMIN_PORT:-9090}}?",
        "build_and_start": "npm run build && npm start"
    }
}
