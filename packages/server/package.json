{
    "name": "@padloc/server",
    "version": "4.4.0",
    "description": "Padloc server component",
    "private": true,
    "files": [
        "src",
        "tsconfig.json"
    ],
    "main": "index.js",
    "author": "Martin Kleinschrodt <martin@maklesoft.com>",
    "license": "GPLv3",
    "devDependencies": {
        "@types/chai": "5.2.3",
        "@types/fs-extra": "11.0.4",
        "@types/jsdom": "21.1.7",
        "@types/mocha": "10.0.10",
        "@types/parse5": "6.0.3",
        "@typescript/typescript6": "6.0.2",
        "chai": "6.2.2",
        "mocha": "11.7.6",
        "ts-node": "10.9.2",
        "ts-node-dev": "1.1.8"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "3.1083.0",
        "@aws-sdk/types": "3.974.0",
        "@padloc/core": "workspace:*",
        "@padloc/locale": "workspace:*",
        "@simplewebauthn/server": "5.4.3",
        "@simplewebauthn/typescript-types": "5.4.0",
        "@types/mixpanel": "2.14.9",
        "@types/node": "18.19.68",
        "@types/nodemailer": "7.0.12",
        "@types/pg": "8.20.0",
        "@types/stripe": "8.0.417",
        "ansi-colors": "4.1.3",
        "date-fns": "4.4.0",
        "dompurify": "3.4.11",
        "dotenv": "17.4.2",
        "fs-extra": "11.3.6",
        "geolite2-redist": "2.0.4",
        "jsdom": "29.1.1",
        "level": "10.0.0",
        "maxmind": "4.3.2",
        "mixpanel": "0.13.0",
        "mongodb": "7.5.0",
        "nodemailer": "7.0.13",
        "pg": "8.22.0",
        "stripe": "8.212.0",
        "typescript": "7.0.2"
    },
    "scripts": {
        "start": "TS_NODE_COMPILER=@typescript/typescript6 ts-node src/init.ts",
        "start-dry": "TS_NODE_COMPILER=@typescript/typescript6 ts-node src/init.ts --dryrun",
        "repl": "TS_NODE_COMPILER=@typescript/typescript6 ts-node src/init-repl-client.ts",
        "dev": "TS_NODE_COMPILER=@typescript/typescript6 ts-node-dev src/init.ts",
        "dev-inspect": "TS_NODE_COMPILER=@typescript/typescript6 node -r ts-node/register --inspect-brk --stack-trace-limit=1000 src/init.ts",
        "test": "tsc --noEmit && cd test && TS_NODE_COMPILER=@typescript/typescript6 TS_NODE_TRANSPILE_ONLY=true mocha -r ts-node/register *.ts --timeout 5000"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/padloc/padloc.git",
        "directory": "packages/server"
    },
    "engines": {
        "node": "24.x"
    }
}
